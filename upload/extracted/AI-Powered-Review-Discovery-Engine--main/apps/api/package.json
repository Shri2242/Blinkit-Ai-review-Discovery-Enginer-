{
  "name": "@review-engine/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "pnpm --filter @review-engine/shared build && pnpm --filter @review-engine/database build && pnpm --filter @review-engine/ai build && tsc",
    "start": "node dist/apps/api/src/server.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@review-engine/ai": "workspace:*",
    "@review-engine/database": "workspace:*",
    "@review-engine/shared": "workspace:*",
    "app-store-scraper": "^0.18.0",
    "bcrypt": "^5.1.1",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "csv-parse": "^7.0.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "firebase-admin": "^14.0.0",
    "google-play-scraper": "^10.1.3",
    "helmet": "^8.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.4.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "rate-limit-redis": "^5.0.0",
    "uuid": "^11.0.3",
    "zod": "^3.25.34"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.13",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "drizzle-orm": "^0.44.2",
    "postgres": "^3.4.7",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
